rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // -------------------------
    // Identity
    // -------------------------

    match /users/{userId} {

      // Users can read only their own identity profile
      allow read:
        if signedIn()
        && request.auth.uid == userId;

      // No client-side modifications
      allow create, update, delete: if false;
    }

    match /userSettings/{userId} {

      // Users may read their own settings
      allow read:
        if signedIn()
        && request.auth.uid == userId;

      // Users may update only their own settings
      allow update:
        if signedIn()
        && request.auth.uid == userId;

      // Settings are created/administered elsewhere
      allow create, delete: if false;
    }

    // -------------------------
    // Everything else (temporary)
    // -------------------------

    match /{document=**} {
      allow read, write: if signedIn();
    }
  }
}

function signedIn() {
  return request.auth != null;
}

function currentUser() {
  return get(
    /databases/$(database)/documents/users/$(request.auth.uid)
  );
}

function currentUserData() {
  return currentUser().data;
}

function tenantId() {
  return currentUserData().tenantId;
}

function role() {
  return currentUserData().role;
}

function isAdmin() {
  return role() == "Administrator";
}

function isSupervisor() {
  return role() == "Supervisor";
}

function isOfficer() {
  return role() == "Officer";
}

function sameTenant() {
  return resource.data.tenantId == tenantId();
}